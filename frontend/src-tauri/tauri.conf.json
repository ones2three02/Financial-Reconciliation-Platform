{
  "build": {
    "distDir": "../dist",
    "devPath": "http://localhost:5174",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "财务自动对账平台",
    "version": "1.0.9"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "save": true
      },
      "fs": {
        "all": false,
        "writeFile": true
      },
      "os": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": "^(?:[a-zA-Z]:\\\\.*|/.*)$"
      },
      "window": {
        "all": false,
        "show": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.ones2three02.reconflow",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/frp-backend"
      ]
    },
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/ones2three02/Financial-Reconciliation-Platform/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczOUIxNUZBOUE5REQ2QTMKUldTajFwMmEraFdiYzQrOFZkeE5vcHYzM25UUEk1eUFmOWxlZ1IwTWFPWWZHaUhyeVRIaWtzZmYK",
      "windows": {
        "installMode": "passive"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "财务自动对账平台",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ]
  }
}
