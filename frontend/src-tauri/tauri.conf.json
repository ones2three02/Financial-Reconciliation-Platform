{
  "build": {
    "distDir": "../dist",
    "devPath": "http://localhost:5174",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "package": {
    "productName": "财务自动对账平台",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": true,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.ones2three02.frpplatform",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/frp-backend"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "财务自动对账平台",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
